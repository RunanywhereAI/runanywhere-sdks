# Public browser flag. It selects the fixed same-origin first-party relay and
# contains no credential or request-controlled upstream.
VITE_RUNANYWHERE_RELAY_ENABLED=true

# Server-only secret used by the Vercel Function and local Vite relay. Never
# rename this to VITE_*: Vite embeds every VITE_* value in the browser bundle.
RUNANYWHERE_API_KEY=YOUR_SERVER_API_KEY

# Optional public value used by browser-release test tooling. The application
# relay itself always uses its compile-time fixed canonical upstream.
VITE_RUNANYWHERE_BASE_URL=https://runanywhere-backend-production.up.railway.app

# User-entered custom endpoints remain direct and must publish their own CORS.
