<?xml version="1.0" encoding="utf-8"?>
<!--
   API 31+ backup/restore rules (data extraction rules).
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!--
          Exclude EncryptedSharedPreferences from cloud backup. The ciphertext is
          encrypted under a non-exportable Android Keystore master key; restoring it
          to a new device (which has a different key) causes GeneralSecurityException
          on every read and silently corrupts all persisted SDK state (device_id,
          auth tokens, etc.).
        -->
        <exclude
            domain="sharedpref"
            path="runanywhere_secure_storage_encrypted.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Same exclusion applies to device-to-device transfers. -->
        <exclude
            domain="sharedpref"
            path="runanywhere_secure_storage_encrypted.xml" />
    </device-transfer>
</data-extraction-rules>
