<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto-backup rules for API < 31 (fullBackupContent).
   See https://developer.android.com/guide/topics/data/autobackup
   Note: devices running API 31+ use data_extraction_rules.xml instead.
-->
<full-backup-content>
    <!--
      Exclude EncryptedSharedPreferences from backup. The ciphertext is
      encrypted under a non-exportable Android Keystore master key; restoring
      it to a new device causes GeneralSecurityException and silently corrupts
      all persisted SDK state (device_id, auth tokens, etc.).
    -->
    <exclude
        domain="sharedpref"
        path="runanywhere_secure_storage_encrypted.xml" />
</full-backup-content>
