<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Model downloads run in a foreground service so multi-GB NPU bundles keep
         transferring when the screen turns off (Doze). WAKE_LOCK keeps the CPU
         servicing the socket; POST_NOTIFICATIONS backs the required progress
         notification (runtime-requested on Android 13+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Vision screen Live mode (in-app CameraX preview). NOTE: because CAMERA is
         declared, the system-camera intent (TakePicturePreview) also requires the
         runtime grant — VisionScreen requests it before either capture path. -->
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:name=".RunAnywhereApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RunAnywhereAI"
        android:usesCleartextTraffic="false"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RunAnywhereAI"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Keeps model downloads alive across screen-off (Doze). dataSync matches
             a network file transfer; the type is also passed to startForeground. -->
        <service
            android:name=".download.ModelDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Zero-dependency ContentProvider that captures the application Context
             before Application.onCreate so the Context-less model picker can launch
             ModelDownloadService. Performs no data operations. -->
        <provider
            android:name=".download.ModelDownloadService$ContextInitializer"
            android:authorities="${applicationId}.modeldownload.contextinit"
            android:exported="false"
            android:initOrder="100" />
    </application>

</manifest>
