# RunAnywhere cloud credentials — used for auth, device registration, and
# telemetry. Copy this file to `.env.local` and fill in your API key.
# Vite only exposes vars prefixed with VITE_ to the app.
VITE_RUNANYWHERE_BASE_URL=https://runanywhere-backend-development.up.railway.app
VITE_RUNANYWHERE_API_KEY=
