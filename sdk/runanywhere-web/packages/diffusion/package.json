{
  "name": "@runanywhere/web-diffusion",
  "version": "0.20.11",
  "description": "RunAnywhere Web SDK - diffusion registration shell awaiting a WebGPU/WASM engine",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:ts": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "verify:package": "node ../../scripts/verify-package.mjs",
    "prepack": "npm run build && npm run verify:package"
  },
  "keywords": [
    "runanywhere",
    "ai",
    "diffusion",
    "image-generation",
    "webgpu",
    "wasm",
    "browser"
  ],
  "author": "RunAnywhere AI",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/RunanywhereAI/runanywhere-sdks.git",
    "directory": "sdk/runanywhere-web/packages/diffusion"
  },
  "homepage": "https://github.com/RunanywhereAI/runanywhere-sdks/tree/main/sdk/runanywhere-web",
  "bugs": {
    "url": "https://github.com/RunanywhereAI/runanywhere-sdks/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "peerDependencies": {
    "@runanywhere/web": ">=0.20.11 <1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
