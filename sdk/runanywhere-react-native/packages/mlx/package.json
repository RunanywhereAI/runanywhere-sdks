{
  "name": "@runanywhere/mlx",
  "version": "0.19.13",
  "description": "MLX backend registration for RunAnywhere React Native SDK on Apple platforms",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "react-native.config.js",
    "*.podspec"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prepublishOnly": "npm run typecheck && npm run lint"
  },
  "keywords": [
    "react-native",
    "runanywhere",
    "mlx",
    "apple",
    "metal",
    "on-device"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@runanywhere/core": ">=0.19.13",
    "react": ">=19.0.0",
    "react-native": ">=0.83.1",
    "react-native-nitro-modules": "^0.33.9"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
