{
  "name": "@runanywhere/qhexrt",
  "version": "0.20.10",
  "private": false,
  "description": "On-device NPU acceleration backend for RunAnywhere (React Native) \u2014 LLM/VLM/STT/TTS on Qualcomm Snapdragon Hexagon (V75/V79/V81), Android arm64.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "cpp",
    "android/src",
    "android/build.gradle",
    "android/CMakeLists.txt",
    "nitrogen",
    "nitro.json",
    "react-native.config.js",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "clean": "tsc -b --clean && rm -rf lib",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "nitrogen": "nitrogen && node ../../scripts/fix-nitrogen-output.js",
    "prepublishOnly": "npm run typecheck && npm run lint"
  },
  "keywords": [
    "react-native",
    "runanywhere",
    "npu",
    "qualcomm",
    "hexagon",
    "qhexrt",
    "on-device",
    "nitro"
  ],
  "homepage": "https://runanywhere.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RunanywhereAI/runanywhere-sdks.git",
    "directory": "sdk/runanywhere-react-native/packages/qhexrt"
  },
  "bugs": {
    "url": "https://github.com/RunanywhereAI/runanywhere-sdks/issues"
  },
  "author": "RunAnywhere AI <team@runanywhere.ai> (https://runanywhere.ai)",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@runanywhere/proto-ts": "workspace:*"
  },
  "peerDependencies": {
    "@runanywhere/core": ">=0.20.10",
    "react": ">=19.0.0",
    "react-native": ">=0.83.1",
    "react-native-nitro-modules": "^0.33.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "nitrogen": "^0.34.1",
    "react-native-nitro-modules": "^0.33.9",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3"
  },
  "create-react-native-library": {
    "languages": "kotlin-swift",
    "type": "nitro-module"
  }
}
