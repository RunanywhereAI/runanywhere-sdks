{
  "name": "@runanywhere/qhexrt",
  "version": "0.19.13",
  "description": "QHexRT backend for RunAnywhere React Native SDK - Qualcomm Hexagon V75/V79/V81 on-device LLM/VLM/STT/TTS (Android arm64 only)",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "cpp",
    "android/src",
    "android/build.gradle",
    "android/CMakeLists.txt",
    "nitrogen",
    "nitro.json",
    "react-native.config.js"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "nitrogen": "nitrogen",
    "prepublishOnly": "npm run typecheck && npm run lint"
  },
  "keywords": [
    "react-native",
    "runanywhere",
    "npu",
    "qualcomm",
    "hexagon",
    "qnn",
    "qhexrt",
    "on-device",
    "nitro"
  ],
  "license": "MIT",
  "dependencies": {
    "@runanywhere/proto-ts": "workspace:*"
  },
  "peerDependencies": {
    "@runanywhere/core": ">=0.19.13",
    "react": ">=19.0.0",
    "react-native": ">=0.83.1",
    "react-native-nitro-modules": "^0.33.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "nitrogen": "^0.34.1",
    "react-native-nitro-modules": "^0.33.9",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3"
  },
  "create-react-native-library": {
    "languages": "kotlin-swift",
    "type": "nitro-module"
  }
}
