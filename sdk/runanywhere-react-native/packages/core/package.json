{
  "name": "@runanywhere/core",
  "version": "0.19.13",
  "description": "Core SDK for RunAnywhere React Native - includes RACommons bindings, native bridges, and public API",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./internal": {
      "source": "./src/internal.ts",
      "types": "./src/internal.ts",
      "default": "./src/internal.ts"
    },
    "./package.json": "./package.json"
  },
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "cpp",
    "ios",
    "!ios/build",
    "android/src",
    "android/build.gradle",
    "android/CMakeLists.txt",
    "android/consumer-rules.pro",
    "nitrogen",
    "nitro.json",
    "react-native.config.js",
    "*.podspec"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "nitrogen": "nitrogen && node scripts/fix-nitrogen-output.js",
    "prepack": "mkdir -p ios/URLSessionHttpTransport && cp -f ../../../shared/ios/URLSessionHttpTransport/URLSessionHttpTransportImpl.inc.mm ios/URLSessionHttpTransport/URLSessionHttpTransportImpl.inc.mm",
    "prepublishOnly": "npm run typecheck && node scripts/fix-nitrogen-output.js"
  },
  "keywords": [
    "react-native",
    "runanywhere",
    "ai",
    "on-device",
    "machine-learning",
    "nitro",
    "expo"
  ],
  "license": "MIT",
  "dependencies": {
    "@runanywhere/proto-ts": "workspace:*",
    "long": "^5.3.2",
    "protobufjs": "^7.5.8"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.83.1",
    "react-native-blob-util": ">=0.19.0",
    "react-native-device-info": ">=11.0.0",
    "react-native-fs": ">=2.20.0",
    "react-native-nitro-modules": "^0.33.9"
  },
  "peerDependenciesMeta": {
    "react-native-blob-util": {
      "optional": true
    },
    "react-native-device-info": {
      "optional": true
    },
    "react-native-fs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.14",
    "jest": "^29.7.0",
    "nitrogen": "^0.34.1",
    "react-native-nitro-modules": "^0.33.9",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3"
  },
  "create-react-native-library": {
    "languages": "kotlin-swift",
    "type": "nitro-module"
  }
}
