_rac_get_platform_adapter
_rac_set_platform_adapter
_rac_platform_services_is_available
_rac_platform_services_register_availability_callback

# Archive Utilities — internal extraction helpers used by the download
# orchestrator. SDKs receive extraction state through download proto bytes.

# Component Types — internal SDK-component identification helpers; the
# canonical contract is the generated SDKComponent enum.

# Download Manager / Orchestrator / File Manager — non-proto APIs are
# internal commons helpers. SDK-facing download/storage/file surfaces use
# the proto-byte ABI (rac_download_*_proto, rac_storage_analyzer_*_proto)
# below. Native HTTP transport is registered through rac_http_transport_*.

# HTTP transport (only the C ABI download executor stays exposed for
# native transport adapters that already wrap it).
_rac_http_download
_rac_http_download_cancel

# Device Manager — platform device-info adapter contract.
_rac_device_set_callbacks

# Events — internal lower-level publisher used by lifecycle manager,
# storage analyzer, device manager, and engine plugins for telemetry
# breadcrumbs. Public SDK event stream is rac_sdk_event_* below.

# Lifecycle / Model Management / Model Paths / Model Registry / Model
# Assignment / Framework Utilities / Module Registry — non-proto
# struct-based APIs are internal commons helpers (still used by JNI
# during migration). SDK-facing surfaces use the proto-byte ABIs:
# rac_model_lifecycle_*_proto, rac_model_registry_*_proto,
# rac_component_lifecycle_snapshot_proto, rac_hardware_*. Plugin/router
# routing is on rac_plugin_* / rac_plugin_route in rac/plugin/.

# LLM Component — non-proto component create/load/generate/etc. APIs are
# now internal (used by JNI bridge during migration). SDK-facing surface is
# the proto-byte ABI (rac_llm_*_proto / rac_llm_set_stream_proto_callback)
# below. Thinking helpers (rac_llm_extract_thinking et al.) moved to
# internal — SDKs read thinking splits from LLMGenerationResult bytes.
# (See docs/CPP_PROTO_OWNERSHIP.md.)

# LoRA Registry — non-proto APIs are internal helpers. SDK-facing LoRA
# surface is the rac_lora_*_proto family below.

# LLM Analytics, generation analytics, streaming metrics — all `internal`
# diagnostics handles. SDK-facing telemetry crosses via SDKEvent /
