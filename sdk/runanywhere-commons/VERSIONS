# =============================================================================
# RunAnywhere Commons - Dependency Versions
# =============================================================================
# This file is the SINGLE SOURCE OF TRUTH for all dependency versions.
# All scripts and CMake files should read from this file via:
#   - Shell scripts: source scripts/load-versions.sh
#   - CMake: include(LoadVersions)
#
# IMPORTANT: These versions MUST match runanywhere-core/VERSIONS
# The ONNX Runtime version used here must match what's in runanywhere-swift/Binaries/
#
# Format: KEY=VALUE (no spaces around =)
# Lines starting with # are comments
# =============================================================================

# Project version (read from VERSION file, but also defined here for scripts)
PROJECT_VERSION=0.19.13

# =============================================================================
# Platform Deployment Targets
# =============================================================================
# iOS minimum deployment target
IOS_DEPLOYMENT_TARGET=13.0

# Android minimum SDK version
ANDROID_MIN_SDK=24

# =============================================================================
# Build Tools
# =============================================================================
# Xcode version for CI/CD builds
XCODE_VERSION=15.4

# Android NDK (matches what scripts/build-android.sh and Kotlin SDK expect)
NDK_VERSION=27.0.12077973

# Emscripten SDK (used by sdk/runanywhere-web/wasm/scripts/build.sh)
EMSCRIPTEN_VERSION=3.1.51

# Node (Web SDK + React Native SDK builds)
NODE_VERSION=20

# JDK (Kotlin SDK + Android builds)
JAVA_VERSION=17

# Gradle wrapper version baseline
GRADLE_VERSION=8.11.1

# CMake version installed in CI. Toolchain present on the build host.
CMAKE_VERSION=3.27

# Minimum CMake version advertised by every `cmake_minimum_required()` in this
# repo. Must be >= 3.24 because cmake/FetchONNXRuntime.cmake uses the
# DOWNLOAD_EXTRACT_TIMESTAMP keyword which was added in CMake 3.24. Bumping
# this drops support for CMake 3.22/3.16/3.14/3.9 hosts; CI/devs need 3.24+.
# NOTE: `cmake_minimum_required(VERSION ...)` must be the first command and
# cannot be parameterised by a CMake variable — keep the literal 3.24 in
# each CMakeLists.txt in sync with this value when bumping.
MIN_CMAKE_VERSION=3.24

# =============================================================================
# ONNX Runtime
# =============================================================================
# iOS version MUST match:
#   1. What sherpa-onnx was built against
#   2. What's in runanywhere-swift/Binaries/onnxruntime.xcframework
# sherpa-onnx 1.12.17+ requires ONNX Runtime >= 1.17.1
ONNX_VERSION_IOS=1.17.1

# Android version - used by Sherpa-ONNX, must be compatible
ONNX_VERSION_ANDROID=1.17.1

# macOS version (can use latest)
ONNX_VERSION_MACOS=1.23.2

# Linux version (can use latest)
ONNX_VERSION_LINUX=1.23.2

# Windows version (can use latest)
ONNX_VERSION_WINDOWS=1.23.2

# =============================================================================
# Sherpa-ONNX (via runanywhere-core)
# =============================================================================
# iOS version
SHERPA_ONNX_VERSION_IOS=1.12.18

# Android version (v1.12.20+ has 16KB alignment for Play Store)
# ⚠️  IMPORTANT: When changing this version, you MUST re-download BOTH the
# prebuilt .so files AND the C API headers to avoid ABI/struct mismatch:
#   rm -rf third_party/sherpa-onnx-android
#   ./scripts/android/download-sherpa-onnx.sh
# The download script now auto-validates header vs .so version consistency.
SHERPA_ONNX_VERSION_ANDROID=1.12.20

# macOS version
SHERPA_ONNX_VERSION_MACOS=1.12.18

# Linux version
SHERPA_ONNX_VERSION_LINUX=1.12.23

# Windows version
SHERPA_ONNX_VERSION_WINDOWS=1.12.23

# =============================================================================
# llama.cpp (LLM inference)
# =============================================================================
# b9174 - latest stable release (May 2026).
# NOTE: Bumped from b8201 to address macOS CI build failure where the vendored
# llama.cpp Metal backend (ggml-metal-context.m) failed to compile against the
# current Xcode SDK with errors like:
#   error: cannot initialize a variable of type 'id<MTLDevice>' with an rvalue
#          of type 'void *' (ggml-metal-context.m)
# Upstream's ggml-metal sources have been refactored multiple times since b8201
# (residency-sets keep-alive, command-buffer failure handling, capture-compute
# counter, etc.). Bumping to a more recent tag picks up those fixes and keeps
# us aligned with the upstream Metal API.
# History: b7650 -> b8201 (enabled GGML_WEBGPU for WASM) -> b9174 (Metal fix).
LLAMACPP_VERSION=b9174

# =============================================================================
# whisper.cpp (STT — opt-in fallback for Whisper-family models)
# =============================================================================
# Pinned tag for engines/whispercpp/CMakeLists.txt FetchContent.
WHISPERCPP_VERSION=v1.8.2

# =============================================================================
# nlohmann/json
# =============================================================================
NLOHMANN_JSON_VERSION=3.11.3

# =============================================================================
# USearch (vector search engine used by the RAG pipeline)
# =============================================================================
USEARCH_VERSION=v2.15.2

# =============================================================================
# cpp-httplib (header-only HTTP server — RAC_BUILD_SERVER only)
# =============================================================================
CPPHTTPLIB_VERSION=v0.15.3

# =============================================================================
# zlib (bundled for Android/Emscripten where the platform SDK lacks it)
# =============================================================================
ZLIB_VERSION=v1.3.1

# =============================================================================
# bzip2 (bundled for Android/Emscripten — sourceware tarball, NOT a `v` prefix)
# =============================================================================
BZIP2_VERSION=1.0.8

# =============================================================================
# Protobuf (libprotobuf runtime + matching libprotobuf-lite/abseil)
# =============================================================================
# Must match what the checked-in generated headers under
# sdk/runanywhere-commons/src/generated/proto/ were emitted by (Protobuf C++
# 7.34.1 → upstream tag v34.1). Bumping requires regenerating those headers.
PROTOBUF_VERSION=34.1

# =============================================================================
# GoogleTest (test framework for commons + RAG unit tests)
# =============================================================================
GOOGLETEST_VERSION=v1.14.0

# =============================================================================
# libarchive (archive extraction - ZIP, TAR.GZ, TAR.BZ2, TAR.XZ)
# =============================================================================
LIBARCHIVE_VERSION=3.8.1

# =============================================================================
# RAC Commons Version (for remote builds/CI)
# =============================================================================
RAC_COMMONS_VERSION=0.1.1
